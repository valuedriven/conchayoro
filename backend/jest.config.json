{
    "roots": [
      "."
    ],
    "reporters": [
      "default",
      [ "jest-junit", { "outputDirectory": "tmp" } ]
  ],
    "collectCoverage": true,
    "coverageDirectory": "tmp/coverage",
    "collectCoverageFrom": [
      "**/src/*/*.js",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/builds/**",
      "!**/src/db/**",
      "!**/src/test/**"
    ],  
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    }
  }